<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Capacitação — <%= raipedia['nome-micro'] %></title>
</head>
<body>

  <%- include("../partials/header") %>

  <!-- HEADER DA PÁGINA -->
  <header>
    <span>RAITec</span>
    <span>Capacitações / Microcontroladores</span>
    <span><%= raipedia['nome-micro'] %> v1.0</span>
  </header>

  <div>

    <!-- SIDEBAR -->
    <aside>
      <nav>

        <div>
          <p>Introdução</p>
          <a href="#visao-geral">Visão Geral</a>
          <a href="#o-que-e">O que é <%= raipedia['nome-micro'] %>?</a>
          <a href="#ambiente">Ambiente de Desenvolvimento</a>
        </div>

        <div>
          <p>Fundamentos</p>
          <a href="#estrutura-codigo">Estrutura do Código <span>B</span></a>
          <a href="#pinos">Pinos e GPIO <span>B</span></a>
          <a href="#digital">I/O Digital <span>B</span></a>
          <a href="#serial">Comunicação Serial <span>B</span></a>
          <a href="#analogico">I/O Analógico <span>B</span></a>
        </div>

        <div>
          <p>Intermediário</p>
          <a href="#pwm">PWM <span>I</span></a>
          <a href="#interrupcoes">Interrupções <span>I</span></a>
          <a href="#i2c">Protocolo I2C <span>I</span></a>
          <a href="#spi">Protocolo SPI <span>I</span></a>
          <a href="#timers">Timers <span>I</span></a>
        </div>

        <div>
          <p>Avançado</p>
          <a href="#memoria">Gerenciamento de Memória <span>A</span></a>
          <a href="#energia">Modos de Energia <span>A</span></a>
          <a href="#rtos">Multitarefa / RTOS <span>A</span></a>
          <a href="#bootloader">Bootloader <span>A</span></a>
        </div>

        <div>
          <p>Projetos</p>
          <a href="#projetos-basicos">Projetos Básicos</a>
          <a href="#projetos-avancados">Projetos Avançados</a>
        </div>

      </nav>
    </aside>

    <!-- MAIN -->
    <main>

      <!-- HERO -->
      <section id="visao-geral">
        <p>Capacitação · Microcontroladores</p>
        <h1><%= raipedia['nome-micro'] %>.</h1>
        <p><%= raipedia['descricao-inicial'] %></p>
      </section>

      <hr/>

      <!-- O QUE É -->
      <section id="o-que-e">
        <p>Introdução</p>
        <h2>O que é <%= raipedia['nome-micro'] %>?</h2>
        <p>Contexto, hardware e ecossistema da plataforma.</p>

        <div>
          <strong>Nota:</strong>
          Embora a capacitação use <%= raipedia['nome-micro'] %> como referência, os conceitos de GPIO, protocolos de comunicação,
          timers e gerenciamento de energia se aplicam diretamente a outros microcontroladores como
          ESP32, STM32, Raspberry Pi Pico e similares.
        </div>

        <p>Legenda: <span>B</span> Básico | <span>I</span> Intermediário | <span>A</span> Avançado</p>

        <ul>
          <li>
            <span>01</span>
            <div>
              <strong>História e Filosofia</strong>
              <p><%= raipedia['o-que-e']['historia'] %></p>
            </div>
            <span>B</span>
          </li>
          <li>
            <span>02</span>
            <div>
              <strong>Variantes de Hardware</strong>
              <p><%= raipedia['o-que-e']['variantes-de-hardware'] %></p>
            </div>
            <span>B</span>
          </li>
          <li>
            <span>03</span>
            <div>
              <strong>Comparativo com outros MCUs</strong>
              <p><%= raipedia['o-que-e']['comparacoes-com-outros-mcus'] %></p>
            </div>
            <span>B</span>
          </li>
        </ul>
      </section>

      <hr/>

      <!-- AMBIENTE -->
      <section id="ambiente">
        <p>Introdução</p>
        <h2>Ambiente de Desenvolvimento</h2>
        <p>IDE, ferramentas e primeiro upload.</p>

        <ul>
          <li>
            <span>01</span>
            <div>
              <strong>Arduino IDE 2.x</strong>
              <p><%= raipedia['ambiente-de-desenvolvimento']['arduino-ide'] %></p>
            </div>
            <span>B</span>
          </li>
          <li>
            <span>02</span>
            <div>
              <strong>PlatformIO + VS Code</strong>
              <p><%= raipedia['ambiente-de-desenvolvimento']['plataformIO-vscode'] %></p>
            </div>
            <span>I</span>
          </li>
          <li>
            <span>03</span>
            <div>
              <strong>Simuladores</strong>
              <p><%= raipedia['ambiente-de-desenvolvimento']['simuladores'] %></p>
            </div>
            <span>B</span>
          </li>
          <li>
            <span>04</span>
            <div>
              <strong>Outras Possibilidades</strong>
              <p><%= raipedia['ambiente-de-desenvolvimento']['outras-possibilidades'] %></p>
            </div>
            <span>I</span>
          </li>
        </ul>
      </section>

      <hr/>

      <!-- FUNDAMENTOS -->
      <section id="estrutura-codigo">
        <p>Fundamentos</p>
        <h2>Fundamentos de Programação</h2>
        <p>Estrutura, variáveis, controle de fluxo e entradas/saídas básicas.</p>

        <ul>
          <li>
            <span>01</span>
            <div>
              <strong>Estrutura do Código</strong>
              <p><%= raipedia['fundamentos-de-programacao']['estrutura-do-codigo'] %></p>
            </div>
            <span>B</span>
          </li>
          <li id="pinos">
            <span>02</span>
            <div>
              <strong>Pinos e GPIO</strong>
              <p><%= raipedia['fundamentos-de-programacao']['descricao-dos-pinos'] %></p>
            </div>
            <span>B</span>
          </li>
          <li id="digital">
            <span>03</span>
            <div>
              <strong>I/O Digital</strong>
              <p><%= raipedia['fundamentos-de-programacao']['io-digital'] %></p>
            </div>
            <span>B</span>
          </li>
          <li id="serial">
            <span>04</span>
            <div>
              <strong>Comunicação Serial (UART)</strong>
              <p><%= raipedia['fundamentos-de-programacao']['comunicacao-serial'] %></p>
            </div>
            <span>B</span>
          </li>
          <li id="analogico">
            <span>05</span>
            <div>
              <strong>I/O Analógico</strong>
              <p><%= raipedia['fundamentos-de-programacao']['io-analogico'] %></p>
            </div>
            <span>B</span>
          </li>
        </ul>
      </section>

      <hr/>

      <!-- INTERMEDIÁRIO -->
      <section id="pwm">
        <p>Intermediário</p>
        <h2>Controle e Protocolos</h2>
        <p>PWM, interrupções e os principais protocolos de comunicação embarcada.</p>

        <ul>
          <li>
            <span>01</span>
            <div>
              <strong>PWM</strong>
              <p><%= raipedia['controle-e-protocolos']['pwm'] %></p>
            </div>
            <span>I</span>
          </li>
          <li id="interrupcoes">
            <span>02</span>
            <div>
              <strong>Interrupções (ISR)</strong>
              <p><%= raipedia['controle-e-protocolos']['interrupcoes'] %></p>
            </div>
            <span>I</span>
          </li>
          <li id="i2c">
            <span>03</span>
            <div>
              <strong>Protocolo I²C</strong>
              <p><%= raipedia['controle-e-protocolos']['protocolo-i2c'] %></p>
            </div>
            <span>I</span>
          </li>
          <li id="spi">
            <span>04</span>
            <div>
              <strong>Protocolo SPI</strong>
              <p><%= raipedia['controle-e-protocolos']['protocolo-spi'] %></p>
            </div>
            <span>I</span>
          </li>
          <li id="timers">
            <span>05</span>
            <div>
              <strong>Timers de Hardware</strong>
              <p><%= raipedia['controle-e-protocolos']['timers-de-hardware'] %></p>
            </div>
            <span>I</span>
          </li>
        </ul>
      </section>

      <hr/>

      <!-- AVANÇADO -->
      <section id="memoria">
        <p>Avançado</p>
        <h2>Tópicos Avançados</h2>
        <p>Otimização, consumo de energia e programação de baixo nível.</p>

        <ul>
          <li>
            <span>01</span>
            <div>
              <strong>Gerenciamento de Memória</strong>
              <p><%= raipedia['topicos-avancados']['gerenciamento-memoria'] %></p>
            </div>
            <span>A</span>
          </li>
          <li id="energia">
            <span>02</span>
            <div>
              <strong>Modos de Baixo Consumo</strong>
              <p><%= raipedia['topicos-avancados']['modos-de-baixo-consumo'] %></p>
            </div>
            <span>A</span>
          </li>
          <li id="rtos">
            <span>03</span>
            <div>
              <strong>Multitarefa com FreeRTOS</strong>
              <p><%= raipedia['topicos-avancados']['multitarefa-com-freeRTOS'] %></p>
            </div>
            <span>A</span>
          </li>
          <li id="bootloader">
            <span>04</span>
            <div>
              <strong>Bootloader e Fuses</strong>
              <p><%= raipedia['topicos-avancados']['bootloader-e-fuses'] %></p>
            </div>
            <span>A</span>
          </li>
        </ul>
      </section>

      <hr/>

      <!-- PROJETOS -->
      <section id="projetos-basicos">
        <p>Projetos</p>
        <h2>Projetos Práticos</h2>
        <p>Aplicações que consolidam os conceitos de cada nível.</p>

        <ul>
          <li>
            <span>B1</span>
            <div>
              <strong>Semáforo com Botão</strong>
              <p><%= raipedia['projetos-praticos']['semaforo-com-botao']['introducao'] %></p>
            </div>
            <span>B</span>
          </li>
        </ul>
      </section>

    </main>
  </div>

</body>
</html>
