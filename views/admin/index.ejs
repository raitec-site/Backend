<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/admin.css">
  <title>Painel Administrativo</title>

</head>

<body>

  <!-- HEADER -->
  <header class="admin-header">

    <h1>
      Painel Administrativo
    </h1>

    <a
      href="/logout"
      class="btn btn-secondary"
    >
      Sair
    </a>

  </header>


  <!-- CONTAINER -->
  <main class="admin-container">

    <!-- GRID -->
    <div class="admin-grid">


      <!-- INÍCIO -->
      <div class="card">

        <h2>
          Início
        </h2>

        <p>
          Gerenciar conteúdos da página inicial.
        </p>

        <a
          href="/admin/inicio"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- MEMBROS -->
      <div class="card">

        <h2>
          Membros
        </h2>

        <p>
          CRUD dos membros do projeto.
        </p>

        <a
          href="/admin/membros"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- ESTRUTURA -->
      <div class="card">

        <h2>
          Estrutura
        </h2>

        <p>
          Gerenciar eixos e times.
        </p>

        <a
          href="/admin/estrutura"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- SOBRE -->
      <div class="card">

        <h2>
          Sobre
        </h2>

        <p>
          Editar informações institucionais.
        </p>

        <a
          href="/admin/sobre"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- PROJETOS -->
      <div class="card">

        <h2>
          Projetos
        </h2>

        <p>
          CRUD dos projetos.
        </p>

        <a
          href="/admin/projetos"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- EVENTOS -->
      <div class="card">

        <h2>
          Eventos
        </h2>

        <p>
          CRUD dos eventos.
        </p>

        <a
          href="/admin/eventos"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- EXTENSÃO -->
      <div class="card">

        <h2>
          Extensão
        </h2>

        <p>
          Gerenciar ações de extensão.
        </p>

        <a
          href="/admin/extensao"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- RAIPÉDIA -->
      <div class="card">

        <h2>
          Raipédia
        </h2>

        <p>
          CRUD dos artigos e capacitações.
        </p>

        <a
          href="/admin/raipedia"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- PROCESSO SELETIVO -->
      <div class="card">

        <h2>
          Processo Seletivo
        </h2>

        <p>
          Editar informações do processo seletivo.
        </p>

        <a
          href="/admin/processo-seletivo"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- NOTÍCIAS -->
      <div class="card">

        <h2>
          Notícias
        </h2>

        <p>
          CRUD das notícias.
        </p>

        <a
          href="/admin/noticias"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


      <!-- CONTATO -->
      <div class="card">

        <h2>
          Contato
        </h2>

        <p>
          Gerenciar informações de contato.
        </p>

        <a
          href="/admin/contato"
          class="btn btn-primary"
        >
          Gerenciar
        </a>

      </div>


    </div>

  </main>

</body>
</html>