<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Editar Membro</title>

  <link rel="stylesheet" href="/css/admin.css">
</head>

<body>

  <!-- HEADER -->
  <header class="admin-header">

    <h1>
      Editar Membro
    </h1>

    <div class="header-buttons">

      <a
        href="/admin/membros"
        class="btn btn-secondary"
      >
        Voltar
      </a>

      <a
        href="/logout"
        class="btn btn-danger"
      >
        Sair
      </a>

    </div>

  </header>


  <!-- CONTAINER -->
  <main class="admin-container">

    <div class="form-card">

      <form
        action="/admin/membros/<%= membro.id %>/editar"
        method="POST"
        class="admin-form"
      >

        <!-- NOME -->
        <div class="form-group">

          <label>
            Nome
          </label>

          <input
            type="text"
            name="nome"
            value="<%= membro.nome %>"
            required
          >

        </div>


        <!-- SLUG -->
        <div class="form-group">

          <label>
            Slug
          </label>

          <input
            type="text"
            name="slug"
            value="<%= membro.slug %>"
            required
          >

        </div>


        <!-- FOTO -->
        <div class="form-group">

          <label>
            URL da Foto
          </label>

          <input
            type="text"
            name="foto"
            value="<%= membro.foto %>"
          >

        </div>


        <!-- EIXO -->
        <div class="form-group">

          <label>
            Eixo
          </label>

          <input
            type="text"
            name="eixo"
            value="<%= membro.eixo %>"
          >

        </div>


        <!-- TIME -->
        <div class="form-group">

          <label>
            Time
          </label>

          <input
            type="text"
            name="time"
            value="<%= membro.time %>"
          >

        </div>


        <!-- DESCRIÇÃO -->
        <div class="form-group">

          <label>
            Descrição
          </label>

          <textarea
            name="descricao"
            rows="5"
          ><%= membro.descricao %></textarea>

        </div>


        <!-- PROJETOS -->
        <div class="form-group">

          <label>
            Projetos
          </label>

          <input
            type="text"
            name="projetos"
            value="<%= membro.projetos ? membro.projetos.join(', ') : '' %>"
          >

          <small>
            Separar projetos por vírgula
          </small>

        </div>


        <!-- ATIVO -->
        <div class="checkbox-group">

          <input
            type="checkbox"
            name="ativo"
            <%= membro.ativo ? "checked" : "" %>
          >

          <label>
            Membro ativo
          </label>

        </div>


        <!-- BOTÕES -->
        <div class="form-actions">

          <button
            type="submit"
            class="btn btn-primary"
          >
            Salvar Alterações
          </button>

        </div>

      </form>

    </div>

  </main>

</body>
</html>