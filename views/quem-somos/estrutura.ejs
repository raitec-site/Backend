<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>RAITec</title>
</head>
<body>

  <%- include("../partials/header") %>

  <h1>Estrutura do Raitec</h1>

<h2>Eixos</h2>
<ul>
  <% eixos.forEach(e => { %>
    <li>
      <a href="/estrutura/<%= e.slug %>">
        <strong><%= e.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>


<h2>Times</h2>
<ul>
  <% times.forEach(t => { %>
    <li>
      <a href="/estrutura/<%= t.slug %>">
        <strong><%= t.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>

</body>
</html>