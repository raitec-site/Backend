      <a href="/projetos/<%= p.slug %>">
        <strong><%= p.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>

<h2>Projetos Finalizados</h2>
<ul>
  <% projetos_finalizados.forEach(p => { %>
    <li>
      <a href="/projetos/<%= p.slug %>">
        <strong><%= p.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>