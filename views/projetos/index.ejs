<h1>Projetos</h1>

<h2>Projetos Ativos</h2>
<ul>
  <% projetos_ativos.forEach(p => { %>
    <li>
      <a href="/projetos/<%= p.slug %>">
        <strong><%= p.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>


