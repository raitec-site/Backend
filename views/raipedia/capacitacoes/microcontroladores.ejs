<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Capacitação — <%= raipedia['nome-micro'] %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/header.css">
  
  <style>
    :root {
      --bg:          #0f1117;
      --surface:     #181c27;
      --border:      #252a38;
      --accent:      #00d4aa;
      --accent-dim:  #00d4aa22;
      --text:        #cdd6f4;
      --text-muted:  #6c7497;
      --text-strong: #e8eaf6;
      --sidebar-w:   280px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      font-size: 15px;
      display: block;
      height: auto;
      justify-content: unset;
      align-items: unset;
    }

    .menu {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 200;
    }

    /* ── SUBHEADER ────────────────────────────────────── */
    .raipedia-subheader {
      position: fixed;
      top: 45px;
      left: 0;
      right: 0;
      z-index: 150;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      height: 36px;
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 12px;
    }

    .subheader-path {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--text-muted);
    }

    .subheader-badge {
      margin-left: auto;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--text-muted);
      background: var(--border);
      padding: 2px 10px;
      border-radius: 3px;
    }

    /* ── LAYOUT ──────────────────────────────────────── */
    .raipedia-layout {
      display: flex;
      padding-top: 81px;
      min-height: 100vh;
    }

    /* ── SIDEBAR ─────────────────────────────────────── */
    .raipedia-aside {
      width: var(--sidebar-w);
      flex-shrink: 0;
      position: fixed;
      top: 81px;
      left: 0;
      bottom: 0;
      overflow-y: auto;
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 24px 0 48px;
    }

    .raipedia-aside::-webkit-scrollbar { width: 4px; }
    .raipedia-aside::-webkit-scrollbar-track { background: transparent; }
    .raipedia-aside::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .nav-group { margin-bottom: 8px; }
    .nav-group-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 12px 20px 6px;
    }
    .nav-link {
      display: flex;
      align-items: center;
      padding: 6px 20px;
      text-decoration: none;
      color: var(--text-muted);
      font-size: 13.5px;
      transition: color 0.15s, background 0.15s;
      border-left: 2px solid transparent;
    }
    .nav-link:hover { color: var(--text); background: var(--accent-dim); }
    .nav-link.active { color: var(--accent); border-left-color: var(--accent); background: var(--accent-dim); }

    /* ── MAIN ────────────────────────────────────────── */
    .raipedia-main {
      margin-left: var(--sidebar-w);
      flex: 1;
      max-width: 860px;
      padding: 56px 64px 120px;
    }

    /* ── SECTIONS ────────────────────────────────────── */
    .doc-section { margin-bottom: 80px; }
    .section-eyebrow {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .section-title {
      font-size: 28px;
      font-weight: 600;
      color: var(--text-strong);
      line-height: 1.25;
      margin-bottom: 16px;
    }
    .section-desc {
      color: var(--text-muted);
      font-size: 14px;
      margin-bottom: 36px;
      max-width: 600px;
    }
    .divider { border: none; border-top: 1px solid var(--border); margin: 48px 0; }

    /* ── TOPIC CARDS ─────────────────────────────────── */
    .topic-grid { display: flex; flex-direction: column; gap: 2px; }
    .topic-card {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 18px 20px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, background 0.15s;
      position: relative;
      overflow: hidden;
    }
    .topic-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--accent);
      opacity: 0;
      transition: opacity 0.15s;
    }
    .topic-card:hover { border-color: var(--accent); background: #1a1f2e; }
    .topic-card:hover::before { opacity: 1; }

    .topic-index {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--text-muted);
      min-width: 28px;
      padding-top: 3px;
    }
    .topic-body { flex: 1; }
    .topic-name { font-weight: 600; font-size: 14.5px; color: var(--text-strong); margin-bottom: 3px; }
    .topic-desc { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

    .topic-arrow { color: var(--text-muted); font-size: 14px; transition: transform 0.15s, color 0.15s; flex-shrink: 0; }
    .topic-card:hover .topic-arrow { transform: translateX(4px); color: var(--accent); }

    /* ── INFO BOX ────────────────────────────────────── */
    .info-box {
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      background: var(--accent-dim);
      border-radius: 4px;
      padding: 16px 20px;
      margin-bottom: 32px;
      font-size: 13.5px;
      color: var(--text);
    }
    .info-box strong {
      color: var(--accent);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      display: block;
      margin-bottom: 6px;
    }

    /* ── HERO ────────────────────────────────────────── */
    .hero {
      margin-bottom: 64px;
      padding-bottom: 48px;
      border-bottom: 1px solid var(--border);
    }
    .hero-kicker {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .hero-title {
      font-size: 42px;
      font-weight: 600;
      color: var(--text-strong);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .hero-title span { color: var(--accent); }
    .hero-sub {
      font-size: 15px;
      color: var(--text-muted);
      max-width: 540px;
      line-height: 1.7;
      font-weight: 300;
    }
    .hero-stats { display: flex; gap: 32px; margin-top: 32px; flex-wrap: wrap; }
    .stat { display: flex; flex-direction: column; gap: 2px; }
    .stat-value {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 22px;
      font-weight: 600;
      color: var(--text-strong);
    }
    .stat-label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 900px) {
      .raipedia-aside { display: none; }
      .raipedia-main { margin-left: 0; padding: 32px 24px 80px; }
    }
  </style>

</head>
<body>

  <%- include("../../partials/header") %>

  <div class="raipedia-subheader">
    <span class="subheader-path">Raipédia / Microcontroladores / <%= raipedia['nome-micro'] %></span>
    <span class="subheader-badge"><%= raipedia['nome-micro'] %> v0.0</span>
  </div>

  <div class="raipedia-layout">

    <!-- SIDEBAR -->
    <aside class="raipedia-aside">
      <nav>
        <div class="nav-group">
          <div class="nav-group-label">Introdução</div>
          <a href="#visao-geral" class="nav-link active">Visão Geral</a>
          <a href="#o-que-e" class="nav-link">O que é <%= raipedia['nome-micro'] %>?</a>
          <a href="#ambiente" class="nav-link">Ambiente de Desenvolvimento</a>
        </div>
        <div class="nav-group">
          <div class="nav-group-label">Fundamentos</div>
          <a href="#estrutura-codigo" class="nav-link">Estrutura do Código</a>
          <a href="#pinos" class="nav-link">Pinos e GPIO</a>
          <a href="#digital" class="nav-link">I/O Digital</a>
          <a href="#serial" class="nav-link">Comunicação Serial</a>
          <a href="#analogico" class="nav-link">I/O Analógico</a>
        </div>
        <div class="nav-group">
          <div class="nav-group-label">Intermediário</div>
          <a href="#pwm" class="nav-link">PWM</a>
          <a href="#interrupcoes" class="nav-link">Interrupções</a>
          <a href="#i2c" class="nav-link">Protocolo I2C</a>
          <a href="#spi" class="nav-link">Protocolo SPI</a>
          <a href="#timers" class="nav-link">Timers</a>
        </div>
        <div class="nav-group">
          <div class="nav-group-label">Avançado</div>
          <a href="#memoria" class="nav-link">Gerenciamento de Memória</a>
          <a href="#energia" class="nav-link">Modos de Energia</a>
          <a href="#rtos" class="nav-link">Multitarefa / RTOS</a>
          <a href="#bootloader" class="nav-link">Bootloader</a>
        </div>
        <div class="nav-group">
          <div class="nav-group-label">Projetos</div>
          <a href="#projetos-basicos" class="nav-link">Projetos Básicos</a>
          <a href="#projetos-avancados" class="nav-link">Projetos Avançados</a>
        </div>
      </nav>
    </aside>

    <!-- MAIN -->
    <main class="raipedia-main">

      <!-- HERO -->
      <section class="hero" id="visao-geral">
        <div class="hero-kicker">Capacitação · Microcontroladores</div>
        <h1 class="hero-title"><%= raipedia['nome-micro'] %><span>.</span></h1>
        <p class="hero-sub"><%= raipedia['descricao-inicial'] %></p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">14</span>
            <span class="stat-label">Tópicos</span>
          </div>
          <div class="stat">
            <span class="stat-value">3</span>
            <span class="stat-label">Seções</span>
          </div>
          <div class="stat">
            <span class="stat-value">0</span>
            <span class="stat-label">Projetos</span>
          </div>
        </div>
      </section>

      <!-- O QUE É -->
      <section class="doc-section" id="o-que-e">
        <div class="section-eyebrow">Introdução</div>
        <h2 class="section-title">O que é <%= raipedia['nome-micro'] %>?</h2>
        <p class="section-desc">Contexto, hardware e ecossistema da plataforma.</p>

        <div class="info-box">
          <strong>Nota</strong>
          Embora a capacitação use <%= raipedia['nome-micro'] %> como referência, os conceitos de GPIO, protocolos de comunicação,
          timers e gerenciamento de energia se aplicam diretamente a outros microcontroladores como
          ESP32, STM32, Raspberry Pi Pico e similares.
        </div>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">História e Filosofia</div>
              <div class="topic-desc"><%= raipedia['o-que-e']['historia'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card">
            <span class="topic-index">02</span>
            <div class="topic-body">
              <div class="topic-name">Variantes de Hardware</div>
              <div class="topic-desc"><%= raipedia['o-que-e']['variantes-de-hardware'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card">
            <span class="topic-index">03</span>
            <div class="topic-body">
              <div class="topic-name">Comparativo com outros MCUs</div>
              <div class="topic-desc"><%= raipedia['o-que-e']['comparacoes-com-outros-mcus'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

      <hr class="divider"/>

      <!-- AMBIENTE -->
      <section class="doc-section" id="ambiente">
        <div class="section-eyebrow">Introdução</div>
        <h2 class="section-title">Ambiente de Desenvolvimento</h2>
        <p class="section-desc">IDE, ferramentas e primeiro upload.</p>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">Arduino IDE 2.x</div>
              <div class="topic-desc"><%= raipedia['ambiente-de-desenvolvimento']['arduino-ide'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card">
            <span class="topic-index">02</span>
            <div class="topic-body">
              <div class="topic-name">PlatformIO + VS Code</div>
              <div class="topic-desc"><%= raipedia['ambiente-de-desenvolvimento']['plataformIO-vscode'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card">
            <span class="topic-index">03</span>
            <div class="topic-body">
              <div class="topic-name">Simuladores</div>
              <div class="topic-desc"><%= raipedia['ambiente-de-desenvolvimento']['simuladores'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card">
            <span class="topic-index">04</span>
            <div class="topic-body">
              <div class="topic-name">Outras Possibilidades</div>
              <div class="topic-desc"><%= raipedia['ambiente-de-desenvolvimento']['outras-possibilidades'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

      <hr class="divider"/>

      <!-- FUNDAMENTOS -->
      <section class="doc-section" id="estrutura-codigo">
        <div class="section-eyebrow">Fundamentos</div>
        <h2 class="section-title">Fundamentos de Programação</h2>
        <p class="section-desc">Estrutura, variáveis, controle de fluxo e entradas/saídas básicas.</p>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">Estrutura do Código</div>
              <div class="topic-desc"><%= raipedia['fundamentos-de-programacao']['estrutura-do-codigo'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="pinos">
            <span class="topic-index">02</span>
            <div class="topic-body">
              <div class="topic-name">Pinos e GPIO</div>
              <div class="topic-desc"><%= raipedia['fundamentos-de-programacao']['descricao-dos-pinos'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="digital">
            <span class="topic-index">03</span>
            <div class="topic-body">
              <div class="topic-name">I/O Digital</div>
              <div class="topic-desc"><%= raipedia['fundamentos-de-programacao']['io-digital'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="serial">
            <span class="topic-index">04</span>
            <div class="topic-body">
              <div class="topic-name">Comunicação Serial (UART)</div>
              <div class="topic-desc"><%= raipedia['fundamentos-de-programacao']['comunicacao-serial'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="analogico">
            <span class="topic-index">05</span>
            <div class="topic-body">
              <div class="topic-name">I/O Analógico</div>
              <div class="topic-desc"><%= raipedia['fundamentos-de-programacao']['io-analogico'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

      <hr class="divider"/>

      <!-- INTERMEDIÁRIO -->
      <section class="doc-section" id="pwm">
        <div class="section-eyebrow">Intermediário</div>
        <h2 class="section-title">Controle e Protocolos</h2>
        <p class="section-desc">PWM, interrupções e os principais protocolos de comunicação embarcada.</p>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">PWM</div>
              <div class="topic-desc"><%= raipedia['controle-e-protocolos']['pwm'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="interrupcoes">
            <span class="topic-index">02</span>
            <div class="topic-body">
              <div class="topic-name">Interrupções (ISR)</div>
              <div class="topic-desc"><%= raipedia['controle-e-protocolos']['interrupcoes'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="i2c">
            <span class="topic-index">03</span>
            <div class="topic-body">
              <div class="topic-name">Protocolo I²C</div>
              <div class="topic-desc"><%= raipedia['controle-e-protocolos']['protocolo-i2c'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="spi">
            <span class="topic-index">04</span>
            <div class="topic-body">
              <div class="topic-name">Protocolo SPI</div>
              <div class="topic-desc"><%= raipedia['controle-e-protocolos']['protocolo-spi'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="timers">
            <span class="topic-index">05</span>
            <div class="topic-body">
              <div class="topic-name">Timers de Hardware</div>
              <div class="topic-desc"><%= raipedia['controle-e-protocolos']['timers-de-hardware'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

      <hr class="divider"/>

      <!-- AVANÇADO -->
      <section class="doc-section" id="memoria">
        <div class="section-eyebrow">Avançado</div>
        <h2 class="section-title">Tópicos Avançados</h2>
        <p class="section-desc">Otimização, consumo de energia e programação de baixo nível.</p>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">Gerenciamento de Memória</div>
              <div class="topic-desc"><%= raipedia['topicos-avancados']['gerenciamento-memoria'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="energia">
            <span class="topic-index">02</span>
            <div class="topic-body">
              <div class="topic-name">Modos de Baixo Consumo</div>
              <div class="topic-desc"><%= raipedia['topicos-avancados']['modos-de-baixo-consumo'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="rtos">
            <span class="topic-index">03</span>
            <div class="topic-body">
              <div class="topic-name">Multitarefa com FreeRTOS</div>
              <div class="topic-desc"><%= raipedia['topicos-avancados']['multitarefa-com-freeRTOS'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
          <a href="#" class="topic-card" id="bootloader">
            <span class="topic-index">04</span>
            <div class="topic-body">
              <div class="topic-name">Bootloader e Fuses</div>
              <div class="topic-desc"><%= raipedia['topicos-avancados']['bootloader-e-fuses'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

      <hr class="divider"/>

      <!-- PROJETOS -->
      <section class="doc-section" id="projetos-basicos">
        <div class="section-eyebrow">Projetos</div>
        <h2 class="section-title">Projetos Práticos</h2>
        <p class="section-desc">Aplicações que consolidam os conceitos de cada seção.</p>

        <div class="topic-grid">
          <a href="#" class="topic-card">
            <span class="topic-index">01</span>
            <div class="topic-body">
              <div class="topic-name">Semáforo com Botão</div>
              <div class="topic-desc"><%= raipedia['projetos-praticos']['semaforo-com-botao']['introducao'] %></div>
            </div>
            <span class="topic-arrow">→</span>
          </a>
        </div>
      </section>

    </main>
  </div>

  <script>
    (function () {
      const menu = document.querySelector('.menu');
      if (!menu) return;

      function applyOffsets() {
        const menuH = menu.offsetHeight;
        const subH  = 36;
        const total = menuH + subH;

        document.querySelector('.raipedia-subheader').style.top = menuH + 'px';
        document.querySelector('.raipedia-layout').style.paddingTop = total + 'px';
        document.querySelector('.raipedia-aside').style.top = total + 'px';
      }

      applyOffsets();
      window.addEventListener('resize', applyOffsets);
    })();

    const sections = document.querySelectorAll('[id]');
    const navLinks = document.querySelectorAll('.nav-link');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.nav-link[href="#${entry.target.id}"]`);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-30% 0px -65% 0px' });

    sections.forEach(s => observer.observe(s));
  </script>

</body>
</html>
