<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>RAITec</title>
</head>
<body>

  <%- include("../partials/header") %>

  <h1>Extensao</h1>

<ul>
  <% extensoes.forEach(e => { %>
    <li>
      <a href="/extensao/<%= e.slug %>">
        <strong><%= e.nome %></strong>
      </a>
    </li>
  <% }) %>
</ul>

</body>
</html>